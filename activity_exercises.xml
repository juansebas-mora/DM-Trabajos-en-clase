<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Formulario Sumar dos números -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Sumar dos números"
            android:textStyle="bold"
            android:textSize="20sp"/>

        <EditText
            android:id="@+id/etNumero1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese el primer número"
            android:inputType="numberDecimal|numberSigned"/>

        <EditText
            android:id="@+id/etNumero2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese el segundo número"
            android:inputType="numberDecimal|numberSigned" />

        <Button
            android:id="@+id/btnSumar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sumar" />

        <TextView
            android:id="@+id/tvResultadoSuma"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resultado: "
            android:textSize="15sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="15dp" />

        <!-- Tienda -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Todo a $15.000"
            android:textStyle="bold"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etCantidadP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese la cantidad de productos"
            android:inputType="number" />

        <EditText
            android:id="@+id/etPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese el monto recibido"
            android:inputType="numberDecimal" />

        <Button
            android:id="@+id/btnCalcularVenta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calcular Venta" />

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total: "
            android:textSize="15sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="15dp" />

        <!-- Conversión F a C -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. Convertir F a C"
            android:textStyle="bold"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese los grados Fahrenheit"
            android:inputType="numberDecimal|numberSigned" />

        <Button
            android:id="@+id/btnConvertirTemp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Convertir" />

        <TextView
            android:id="@+id/tvResultadoTemp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grados Celsius: "
            android:textSize="15sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="15dp" />

        <!-- Dosis Vacuna -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4. Dosis Vacuna"
            android:textStyle="bold"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/etPeso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese el peso (kg)"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/etEdad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese la edad"
            android:inputType="number" />

        <Button
            android:id="@+id/btnCalcularDosis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calcular Dosis" />

        <TextView
            android:id="@+id/tvResultadoDosis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dosis: "
            android:textSize="15sp"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>
